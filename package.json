{
  "name": "music-player",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:unit": "vitest run tests/unit",
    "verify": "npm run test:unit && npm run test:e2e && npm run tauri:build:portable",
    "tauri:build": "npx tauri build --config src-tauri/tauri.conf.json",
    "tauri:build:portable": "npx tauri build --config src-tauri/tauri.conf.json --no-bundle"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@tauri-apps/cli": "^2.11.0",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.1",
    "vitest": "^2.0.5"
  }
}
